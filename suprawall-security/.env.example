# Installation method: local (debug daemon) or remote (live install)
INSTALL_METHOD=remote

# Remote Dify Instance (cloud.dify.ai or self-hosted)
REMOTE_INSTALL_HOST=cloud.dify.ai
REMOTE_INSTALL_PORT=443

# Debug Key from Dify.ai → Settings → Plugins → Debug Key
# Obtain at: https://cloud.dify.ai/account/plugins
REMOTE_INSTALL_KEY=your-dify-plugin-debug-key

# Optional: SupraWall API Key for local testing (sw_...)
SUPRAWALL_API_KEY=sw_your_key_here
