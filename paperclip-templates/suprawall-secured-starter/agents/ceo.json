{
  "name": "CEO Agent",
  "role": "ceo",
  "description": "Orchestrates company strategy and has read-only access to all dashboards.",
  "adapter": {
    "type": "http",
    "url": "https://api.supra-wall.com/v1/agent/invoke",
    "headers": {
      "Authorization": "Bearer {{SUPRAWALL_API_KEY}}"
    },
    "body": {
      "agentId": "{{agent.id}}",
      "companyId": "{{company.id}}",
      "role": "ceo",
      "runId": "{{run.id}}"
    }
  }
}
